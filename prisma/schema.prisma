generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum OrgPlan {
  free
  starter
  pro
  agency
  scale
}

enum OrgMemberRole {
  admin
  trafficker
  client
}

enum OrgMemberStatus {
  active
  invited
  suspended
}

enum UserRole {
  CEO
  Manager
  Team
}

enum UserStatus {
  active
  inactive
  invited
}

enum TaskStatus {
  pending
  in_progress
  review
  completed
  rejected
}

enum Priority {
  critical
  high
  medium
  low
}

enum ReportType {
  task_completion
  change
  issue
  insight
  client_update
  monthly
  weekly
}

enum ValidationStatus {
  pending
  validated
  rejected
  review
}

enum AuditStatus {
  draft
  completed
  closed
}

enum AuditResult {
  compliant
  partial
  non_compliant
}

enum DocCategory {
  sop
  manual
  template
  process
  reference
  policy
  contract
  onboarding
  legal
  finances
}

enum DocStatus {
  draft
  published
  archived
}

enum ClientStatus {
  active
  paused
  inactive
  onboarding
  risk
  scaling
}

enum NotificationType {
  task
  report
  audit
  alert
  general
  invitation
  payment
}

enum ProjectStatus {
  onboarding
  active
  review
  paused
  completed
}

enum ServiceType {
  meta_ads
  google_ads
  landing_page
  ecommerce
  mentoring
  social_media
  seo
  email_marketing
  content
  design
  other
}

enum ObjectiveType {
  organization
  team
  personal
}

enum ObjectiveStatus {
  active
  completed
  cancelled
}

// ─── MULTI-TENANT MODELS ───────────────────────────────────────────────────────

model Organization {
  id         String   @id @default(uuid())
  name       String
  slug       String   @unique
  ownerId    String
  plan       OrgPlan  @default(free)
  maxUsers   Int      @default(1)
  maxClients Int      @default(2)
  logoUrl    String?
  website    String?
  industry   String?
  country    String?
  currency   String   @default("USD")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members       OrganizationMember[]
  invitations   Invitation[]
  clients       Client[]
  projects      Project[]
  tasks         Task[]
  reports       Report[]
  audits        Audit[]
  docs          Documentation[]
  notifications Notification[]
  activityLog   ActivityLog[]
  finances      Finance[]
  objectives    Objective[]
  kpis          KPI[]
  meetings      Meeting[]
  recordings    Recording[]

  @@map("organizations")
}

model OrganizationMember {
  id             String          @id @default(uuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           OrgMemberRole   @default(trafficker)
  status         OrgMemberStatus @default(active)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([organizationId, userId])
  @@map("organization_members")
}

model Invitation {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           OrgMemberRole @default(trafficker)
  token          String        @unique @default(uuid())
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime      @default(now())

  @@map("invitations")
}

// ─── USER ─────────────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  fullName     String
  role         UserRole   @default(Team)
  department   String?
  status       UserStatus @default(active)
  avatarUrl    String?
  phone        String?
  isFreelancer Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  lastLogin    DateTime?

  organizationMembers OrganizationMember[]
  tasksCreated        Task[]               @relation("TaskCreator")
  tasksValidated      Task[]               @relation("TaskValidator")
  reportsSubmitted    Report[]             @relation("ReportSubmitter")
  reportsValidated    Report[]             @relation("ReportValidator")
  auditsCreated       Audit[]              @relation("AuditCreator")
  docsAuthored        Documentation[]
  clientsManaged      Client[]             @relation("AccountManager")
  notifications       Notification[]
  activityLog         ActivityLog[]
  comments            Comment[]
  projectsManaged     Project[]
  meetingsCreated     Meeting[]            @relation("MeetingCreator")
  recordingsCreated   Recording[]          @relation("RecordingCreator")

  @@map("users")
}

// ─── CLIENT (CRM) ─────────────────────────────────────────────────────────────

model Client {
  id               String       @id @default(uuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name             String
  brand            String?
  email            String?
  phone            String?
  whatsapp         String?
  contactPerson    String?
  country          String?
  currency         String       @default("USD")
  accountManagerId String?
  accountManager   User?        @relation("AccountManager", fields: [accountManagerId], references: [id])
  status           ClientStatus @default(active)
  industry         String?
  website          String?
  notes            String?
  observations     String?

  // Financial
  monthlyFee       Decimal? @db.Decimal(12, 2)
  commissionPct    Decimal? @db.Decimal(5, 2)
  monthlySales     Decimal? @db.Decimal(12, 2)
  commissionCalc   Decimal? @db.Decimal(12, 2)
  totalToBill      Decimal? @db.Decimal(12, 2)
  paymentStatus    String?
  contractStart    DateTime?
  contractEnd      DateTime?
  serviceType      String?

  // Accesses
  facebookUrl      String?
  instagramUrl     String?
  tiktokUrl        String?
  googleAdsId      String?
  websiteUrl       String?
  metaBmId         String?
  adAccountId      String?
  pixelId          String?
  extraLinks       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects   Project[]
  tasks      Task[]
  reports    Report[]
  audits     Audit[]
  finances   Finance[]
  kpis       KPI[]
  meetings   Meeting[]
  recordings Recording[]

  @@map("clients")
}

// ─── PROJECT ──────────────────────────────────────────────────────────────────

model Project {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId       String?
  client         Client?       @relation(fields: [clientId], references: [id])
  managerId      String?
  manager        User?         @relation(fields: [managerId], references: [id])
  name           String
  description    String?
  serviceType    ServiceType?
  status         ProjectStatus @default(active)
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tasks Task[]

  @@map("projects")
}

// ─── TASK ─────────────────────────────────────────────────────────────────────

model Task {
  id                String     @id @default(uuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title             String
  description       String?
  createdById       String
  createdBy         User       @relation("TaskCreator", fields: [createdById], references: [id])
  assignedTo        String[]
  deadline          DateTime?
  clientId          String?
  client            Client?    @relation(fields: [clientId], references: [id])
  projectId         String?
  project           Project?   @relation(fields: [projectId], references: [id])
  department        String?
  status            TaskStatus @default(pending)
  progressPercent   Int        @default(0)
  sopLink           String?
  estimatedHours    Int?
  actualHours       Int?
  priority          Priority   @default(medium)
  taskType          String?
  isRecurring       Boolean    @default(false)
  recurrencePattern String?
  parentTaskId      String?
  parentTask        Task?      @relation("Subtasks", fields: [parentTaskId], references: [id])
  subtasks          Task[]     @relation("Subtasks")
  validatedById     String?
  validatedBy       User?      @relation("TaskValidator", fields: [validatedById], references: [id])
  validatedAt       DateTime?
  validationNotes   String?
  checklist         Json?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  reports     Report[]
  comments    Comment[]
  activityLog ActivityLog[]

  @@map("tasks")
}

// ─── REPORT ───────────────────────────────────────────────────────────────────

model Report {
  id                 String           @id @default(uuid())
  organizationId     String
  organization       Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title              String
  description        String
  submittedById      String
  submittedBy        User             @relation("ReportSubmitter", fields: [submittedById], references: [id])
  submittedAt        DateTime         @default(now())
  reportType         ReportType
  clientId           String?
  client             Client?          @relation(fields: [clientId], references: [id])
  taskId             String?
  task               Task?            @relation(fields: [taskId], references: [id])
  fileUrls           String[]
  status             ValidationStatus @default(pending)
  validatedById      String?
  validatedBy        User?            @relation("ReportValidator", fields: [validatedById], references: [id])
  validatedAt        DateTime?
  validationComments String?
  priority           Priority         @default(medium)
  tags               String[]

  // Monthly/Weekly report fields
  investment         Decimal?  @db.Decimal(12, 2)
  sales              Decimal?  @db.Decimal(12, 2)
  roas               Decimal?  @db.Decimal(8, 2)
  previousSales      Decimal?  @db.Decimal(12, 2)
  growthPct          Decimal?  @db.Decimal(8, 2)
  tasksCompleted     Int?
  tasksPending       Int?
  nextMonthPlan      String?
  sentToClient       Boolean   @default(false)
  sentAt             DateTime?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  comments    Comment[]
  activityLog ActivityLog[]

  @@map("reports")
}

// ─── AUDIT ────────────────────────────────────────────────────────────────────

model Audit {
  id                   String       @id @default(uuid())
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title                String
  processName          String
  auditedUsers         String[]
  clientId             String?
  client               Client?      @relation(fields: [clientId], references: [id])
  auditFrom            DateTime
  auditTo              DateTime
  createdById          String
  createdBy            User         @relation("AuditCreator", fields: [createdById], references: [id])
  createdAt            DateTime     @default(now())
  executedAt           DateTime?
  findings             Json?
  complianceScore      Int?
  overallStatus        AuditResult?
  notes                String?
  correctiveActions    String?
  correctiveActionsDue DateTime?
  status               AuditStatus  @default(draft)
  updatedAt            DateTime     @updatedAt

  activityLog ActivityLog[]

  @@map("audits")
}

// ─── DOCUMENTATION ────────────────────────────────────────────────────────────

model Documentation {
  id           String      @id @default(uuid())
  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title        String
  content      String
  category     DocCategory
  subcategory  String?
  authorId     String
  author       User        @relation(fields: [authorId], references: [id])
  version      Int         @default(1)
  versionNotes String?
  tags         String[]
  status       DocStatus   @default(draft)
  externalUrl  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("documentation")
}

// ─── FINANCE ──────────────────────────────────────────────────────────────────

model Finance {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId       String?
  client         Client?      @relation(fields: [clientId], references: [id])
  type           String       // income, expense, salary, commission
  category       String?      // fee, commission, salary, tool, ads_spend, other
  description    String
  amount         Decimal      @db.Decimal(12, 2)
  currency       String       @default("USD")
  date           DateTime
  month          Int
  year           Int
  isPaid         Boolean      @default(false)
  paidAt         DateTime?
  paymentMethod  String?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("finances")
}

// ─── KPI ──────────────────────────────────────────────────────────────────────

model KPI {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId       String?
  client         Client?      @relation(fields: [clientId], references: [id])
  month          Int
  year           Int
  investment     Decimal?     @db.Decimal(12, 2)
  sales          Decimal?     @db.Decimal(12, 2)
  roas           Decimal?     @db.Decimal(8, 2)
  cpa            Decimal?     @db.Decimal(8, 2)
  avgTicket      Decimal?     @db.Decimal(8, 2)
  growthPct      Decimal?     @db.Decimal(8, 2)
  clicks         Int?
  impressions    Int?
  ctr            Decimal?     @db.Decimal(8, 4)
  conversions    Int?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, clientId, month, year])
  @@map("kpis")
}

// ─── OBJECTIVE ────────────────────────────────────────────────────────────────

model Objective {
  id             String          @id @default(uuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  type           ObjectiveType   @default(organization)
  target         Decimal         @db.Decimal(12, 2)
  current        Decimal         @default(0) @db.Decimal(12, 2)
  unit           String          @default("%")
  startDate      DateTime
  endDate        DateTime
  status         ObjectiveStatus @default(active)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@map("objectives")
}

// ─── NOTIFICATION ─────────────────────────────────────────────────────────────

model Notification {
  id                String           @id @default(uuid())
  organizationId    String?
  organization      Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId            String
  user              User             @relation(fields: [userId], references: [id])
  title             String
  message           String
  type              NotificationType
  priority          Priority         @default(medium)
  relatedEntityType String?
  relatedEntityId   String?
  isRead            Boolean          @default(false)
  readAt            DateTime?
  deliveryMethods   String[]
  deliveredAt       DateTime?
  createdAt         DateTime         @default(now())
  expiresAt         DateTime?

  @@map("notifications")
}

// ─── COMMENT ──────────────────────────────────────────────────────────────────

model Comment {
  id        String   @id @default(uuid())
  text      String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id])
  reportId  String?
  report    Report?  @relation(fields: [reportId], references: [id])
  createdAt DateTime @default(now())

  @@map("comments")
}

// ─── MEETING / MINUTA ────────────────────────────────────────────────────────

model Meeting {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId       String?
  client         Client?      @relation(fields: [clientId], references: [id])
  title          String
  date           DateTime
  attendees      String[]
  summary        String?
  decisions      String?
  agreedTasks    Json?        // [{title, assignedTo, deadline}]
  nextMeetingDate DateTime?
  notes          String?
  fileUrls       String[]
  createdById    String
  createdBy      User         @relation("MeetingCreator", fields: [createdById], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("meetings")
}

// ─── RECORDING ───────────────────────────────────────────────────────────────

model Recording {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientId       String?
  client         Client?      @relation(fields: [clientId], references: [id])
  meetingId      String?
  title          String
  url            String?
  platform       String?      // zoom, meet, loom, other
  duration       Int?         // minutes
  transcription  String?
  extractedTasks Json?        // [{title, assignedTo}]
  createdById    String
  createdBy      User         @relation("RecordingCreator", fields: [createdById], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("recordings")
}

// ─── ACTIVITY LOG ─────────────────────────────────────────────────────────────

model ActivityLog {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  actionType     String
  entityType     String?
  entityId       String?
  taskId         String?
  task           Task?         @relation(fields: [taskId], references: [id])
  reportId       String?
  report         Report?       @relation(fields: [reportId], references: [id])
  auditId        String?
  audit          Audit?        @relation(fields: [auditId], references: [id])
  changes        Json?
  description    String?
  createdAt      DateTime      @default(now())

  @@map("activity_log")
}
